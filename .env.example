# Copy this to .env and fill in values

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=monitor.schaff.cc,localhost

# PostgreSQL
DATABASE_URL=postgres://netmon:password@localhost:5432/network_dashboard

# Redis
REDIS_URL=redis://localhost:6379/0

# LDAP
LDAP_BIND_DN=CN=svc_network-monitor-t0,CN=Users,DC=schaff,DC=cc
LDAP_BIND_PASSWORD=your-svc-account-password-here

# Home Assistant
HA_TOKEN=your-long-lived-access-token-here

# Optional: override default location for weather (Madison, WI)
# WEATHER_LAT=43.0731
# WEATHER_LON=-89.4012
